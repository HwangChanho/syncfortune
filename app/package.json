{
  "name": "syncfortune-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev": "(sleep 12 && npm run connect &) ; npm_config_cache=/tmp/npmcache-sf PATH=\"/opt/homebrew/bin:$PATH\" expo start --port 8083 --localhost",
    "connect": "xcrun simctl terminate 82FF7B65-7203-4FCE-8196-F8BAF697AF52 com.syncfortune.app 2>/dev/null; xcrun simctl openurl 82FF7B65-7203-4FCE-8196-F8BAF697AF52 \"syncfortune://expo-development-client/?url=http%3A%2F%2Flocalhost%3A8083\"",
    "ios": "expo run:ios --device \"82FF7B65-7203-4FCE-8196-F8BAF697AF52\"",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-linking": "~7.0.5",
    "expo-localization": "~16.0.1",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.0",
    "i18next": "^26.3.1",
    "intl-pluralrules": "^2.0.1",
    "iztro": "^2.5.8",
    "lunar-javascript": "^1.7.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
