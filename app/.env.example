# app/.env.example — 앱 환경변수 템플릿
# 사용법:  cp app/.env.example app/.env  후 실제 값을 채우세요. (app/.env 는 gitignore)
#
# Supabase 클라이언트 연결값. anon key 는 RLS 로 보호되는 *공개* 키지만,
# 라이브 백엔드(특히 과금되는 Edge 함수) 남용을 막기 위해 레포에 박지 않고 .env 로 주입한다.
# Expo 는 EXPO_PUBLIC_* 접두 변수만 클라이언트 번들에 인라인한다.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── 인앱결제 (RevenueCat) — 대시보드 Project → API Keys(Apple/Google 앱별 *공개* SDK 키) ──
#   미설정 시 결제 UI 는 '준비 중' 폴백(빌드/실행 무탈). 상품 id=unlock_2500·unlock_4900, entitlement=premium.
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=

# ── 광고 (AdMob) — 콘솔의 광고 단위(unit) ID. 미설정 시 구글 테스트 unit 폴백 ──
#   ※ 앱 ID(ca-app-pub-…~…)는 app.json 의 react-native-google-mobile-ads 플러그인에서 별도 교체.
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
