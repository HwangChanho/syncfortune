{
  "expo": {
    "name": "팔자(八字)",
    "slug": "syncfortune",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "syncfortune",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syncfortune.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.syncfortune.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-router",
      "expo-localization",
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2936938026486482~6976735795",
          "iosAppId": "ca-app-pub-2936938026486482~5922674426"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "supabaseUrl": "https://YOUR_PROJECT_REF.supabase.co",
      "supabaseAnonKey": "YOUR_SUPABASE_ANON_KEY",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "72e189fd-50b9-45b1-b1a9-e0e89f37b3ef"
      }
    },
    "owner": "danielhwang"
  }
}
